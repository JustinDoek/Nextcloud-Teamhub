# Suppress EBADENGINE warnings — our project supports Node >=18 including 24.x
engine-strict=false

# Show only errors, suppress info/warn noise during install
loglevel=error

# Don't auto-run audit on install (run manually with npm audit when needed)
# The remaining vuln reports are all in the Vue 2 ecosystem that Nextcloud 32
# itself depends on — upgrading would break NC32 compatibility.
audit=false
